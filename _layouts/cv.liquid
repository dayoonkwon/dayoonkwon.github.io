---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
  </header>

  {% if page.cv_pdf %}
    <div class="d-flex justify-content-end" style="margin-bottom: 20px;">
      <a href="{{ page.cv_pdf | relative_url }}" target="_blank" rel="noopener noreferrer">
        <i class="fas fa-file-pdf" style="font-size: 2rem; color: #9b4dca;"></i>
      </a>
    </div>
    <div class="col p-0 pt-4 pb-4">
      <iframe src="{{ page.cv_pdf | relative_url }}" 
              width="100%" height="900px" style="border: none;">
      </iframe>
    </div>
  {% endif %}
</div>
