---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    <p class="post-description">{{ page.description }}</p>
  </header>

  {% if page.cv_pdf %}
    <div class="d-flex justify-content-end" style="margin-bottom: 20px;">
      <a href="{{ page.cv_pdf | prepend: '/assets/pdf/' | relative_url }}" 
         target="_blank" 
         rel="noopener noreferrer">
        <img src="{{ '/assets/img/pdf_icon.png' | relative_url }}" 
             alt="PDF Icon" style="width:40px;">
      </a>
    </div>
    <div class="col p-0 pt-4 pb-4">
      <iframe src="{{ page.cv_pdf | prepend: '/assets/pdf/' | relative_url }}" 
              width="100%" height="800px" style="border: none;">
      </iframe>
    </div>
  {% endif %}

  {{ content }}
</div>
